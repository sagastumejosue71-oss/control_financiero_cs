APP_NAME="Finanzas GT"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

# Si despliegas detrás de un reverse proxy/load balancer que termina el HTTPS
# (Nginx, Cloudflare, etc.), lista aquí sus IPs separadas por coma, o usa "*"
# si el proxy es de confianza total. Vacío = no confiar en ningún proxy.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Aumentar rounds en producción (12 mínimo recomendado)
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# En producción usa 'error' o 'warning', nunca 'debug'
LOG_LEVEL=error

# ─── Base de datos ────────────────────────────────────────────────────────────
# SQLite por defecto (no exponer el archivo en repositorios)
DB_CONNECTION=sqlite
# Para MySQL/PostgreSQL en producción:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=finanzas_gt
# DB_USERNAME=db_user
# DB_PASSWORD=

# ─── Sesiones (configuración segura) ─────────────────────────────────────────
# "database" sobrevive reinicios/redeploys del contenedor (importante en hosting
# sin disco persistente); usa "file" solo si tienes disco persistente garantizado.
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

# ─── Colas y cache ───────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Redis (opcional, para producción de alta carga) ─────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Correo ───────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@tudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Obtén las credenciales en: https://console.cloud.google.com
# APIs & Services → Credentials → Create OAuth 2.0 Client ID
# URI de redirección autorizado: https://tudominio.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Vite ────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
